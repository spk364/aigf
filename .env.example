# ─── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (must have pgvector extension enabled)
DATABASE_URL=postgresql://user:password@localhost:5432/gfai

# Payload CMS secret — must be at least 32 characters
PAYLOAD_SECRET=replace-me-with-a-random-32-char-secret-here

# Publicly accessible base URL of the app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Runtime environment
NODE_ENV=development

# ─── AI / LLM ─────────────────────────────────────────────────────────────────

OPENROUTER_API_KEY=
FAL_KEY=
# OPTIONAL warm fal NSFW endpoints. Hard-NSFW (explicit nudity) needs a Pony/
# Illustrious checkpoint; on fal those only run COLD via fal-ai/lora and time out.
# The default warm path is Novita (below). If you instead deploy a WARM fal
# endpoint (fal.App + min_concurrency / dedicated), put its id here to override
# Novita per style.
FAL_NSFW_ANIME_ENDPOINT=
FAL_NSFW_REALISTIC_ENDPOINT=
# Atlas Cloud — NSFW-friendly video provider (WAN 2.2 Turbo Spicy etc.).
# Used as primary for image-to-video; fal stays as fallback for SFW images.
ATLAS_API_KEY=
# Novita.ai — DEFAULT warm provider for explicit-nudity chat photos. Always-warm
# Pony/Illustrious SDXL checkpoints, NSFW detection off. REQUIRED for hard-NSFW
# photos unless a warm fal endpoint is set above; without either, explicit photos
# fail gracefully (the text reply still sends).
NOVITA_API_KEY=
# Optional per-style Novita checkpoint overrides (sd_name from Novita's library).
# Default for both is Pony Diffusion V6 XL; set NOVITA_REALISTIC_MODEL to a
# realism-tuned checkpoint (e.g. a CyberRealistic Pony) for best photorealism.
NOVITA_ANIME_MODEL=
NOVITA_REALISTIC_MODEL=
# Legacy single-checkpoint override (still honoured as the anime fallback).
NOVITA_IMAGE_MODEL=
OPENAI_API_KEY=
# Safety: apparent-age classifier endpoint (fal-hosted, NSFW-tolerant VLM).
# Defaults to fal-ai/llava-next when unset (verified: follows the JSON prompt,
# ~3s). The classifier MUST be reachable in production — without FAL_KEY the
# image gate fails CLOSED (blocks all generated images).
AGE_CLASSIFIER_FAL_ENDPOINT=
# Output-side apparent-age gate for CHAT photos: off (default) | fail_open |
# strict. Off by default because the fal-hosted classifier scales to zero and
# cold-boots in 60-100s, stalling/failing every "first photo after idle".
# Prompt-side age controls (age-safety.ts) still apply at generation time;
# builder previews keep their own gate (image-age-gate.ts) regardless.
CHAT_IMAGE_AGE_GATE=

# ─── Staging password gate (optional) ─────────────────────────────────────────
# When set, requests to *.vercel.app hosts (preview + unattached prod alias)
# require HTTP Basic Auth with this password. Username is ignored. Leave
# blank to disable. Set FORCE_BASIC_AUTH=1 to also require it on custom
# domains (typically only useful for an unreleased prod).
SITE_PASSWORD=
FORCE_BASIC_AUTH=

# ─── Email ────────────────────────────────────────────────────────────────────

RESEND_API_KEY=

# ─── Cache / Queue ────────────────────────────────────────────────────────────

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Object Storage (Cloudflare R2) ───────────────────────────────────────────

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ─── Payments — CCBill ────────────────────────────────────────────────────────

CCBILL_ACCOUNT_NUM=
CCBILL_SUBACCOUNT_NUM=
CCBILL_SALT=
CCBILL_WEBHOOK_SECRET=

# ─── Payments — NOWPayments (crypto) ─────────────────────────────────────────
# API key from https://nowpayments.io (or https://account-sandbox.nowpayments.io
# for testing). IPN secret is generated separately under Store Settings → IPN.
# NOWPAYMENTS_ENV controls the API base URL:
#   - "production" (default) → https://api.nowpayments.io
#   - "sandbox"              → https://api-sandbox.nowpayments.io
# Sandbox accepts testnet coins; production accepts real funds. Switching is
# explicit so a forgotten variable on a real deploy can't accept fake payments.

NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_ENV=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Optional — set both to enable "Continue with Google" sign-in.
# Create credentials at: https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3000/api/users/oauth/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to "true" to enable the Google button (auto-derived from above when both are set)
GOOGLE_OAUTH_ENABLED=

# ─── Observability ────────────────────────────────────────────────────────────

SENTRY_DSN=
# Client-side Sentry (same DSN, exposed to browser)
NEXT_PUBLIC_SENTRY_DSN=

POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com
# Client-side PostHog (exposed to browser)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

AXIOM_TOKEN=
AXIOM_DATASET=

# ─── Dev only ─────────────────────────────────────────────────────────────────
# Set to "true" to bypass auth in development. Every request resolves as the
# seeded dev user (dev@local.test) — premium_plus, NSFW unlocked, 500+ tokens.
# Run `pnpm seed:dev` once to create the user. Refused in production.
DEV_AUTH_BYPASS=

# Storage provider override. Omit to auto-detect:
#   - "r2"    — always use Cloudflare R2 (requires R2_* vars above)
#   - "local" — save files to public/uploads/ and serve via Next.js (dev only)
# Without R2_* vars configured, defaults to "local" in development.
STORAGE_PROVIDER=
