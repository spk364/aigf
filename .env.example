# ─── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (must have pgvector extension enabled)
DATABASE_URL=postgresql://user:password@localhost:5432/gfai

# Payload CMS secret — must be at least 32 characters
PAYLOAD_SECRET=replace-me-with-a-random-32-char-secret-here

# Publicly accessible base URL of the app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Runtime environment
NODE_ENV=development

# ─── AI / LLM ─────────────────────────────────────────────────────────────────

OPENROUTER_API_KEY=
FAL_KEY=
OPENAI_API_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────

RESEND_API_KEY=

# ─── Cache / Queue ────────────────────────────────────────────────────────────

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Object Storage (Cloudflare R2) ───────────────────────────────────────────

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ─── Payments — CCBill ────────────────────────────────────────────────────────

CCBILL_ACCOUNT_NUM=
CCBILL_SUBACCOUNT_NUM=
CCBILL_SALT=
CCBILL_WEBHOOK_SECRET=

# ─── Payments — NOWPayments (crypto) ─────────────────────────────────────────

NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Optional — set both to enable "Continue with Google" sign-in.
# Create credentials at: https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3000/api/users/oauth/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to "true" to enable the Google button (auto-derived from above when both are set)
GOOGLE_OAUTH_ENABLED=

# ─── Observability ────────────────────────────────────────────────────────────

SENTRY_DSN=
# Client-side Sentry (same DSN, exposed to browser)
NEXT_PUBLIC_SENTRY_DSN=

POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com
# Client-side PostHog (exposed to browser)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

AXIOM_TOKEN=
AXIOM_DATASET=
